import React, { useEffect, useRef, useState } from 'react';
import { ArrowRight, ArrowLeft } from 'lucide-react';

// --- DATA STUDI KASUS ($20K VIBE) ---
// Fokus pada masalah klien (Challenge) dan hasil (Impact)
const cases = [
  {
