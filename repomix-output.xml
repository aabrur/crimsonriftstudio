// --- KOMPONEN KARTU DENGAN EFEK 3D TILT ---
function TiltCard({ item, index }) {
  const cardRef = useRef(null);
  const [tilt, setTilt] = useState({ x: 0, y: 0 });
  const [isHovered, setIsHovered] = useState(false);

  const handleMouseMove = (e) => {
    if (!cardRef.current) return;
    const rect = cardRef.current.getBoundingClientRect();
    const x = e.clientX - rect.left;
    const y = e.clientY - rect.top;
    
    const centerX = rect.width / 2;
    const centerY = rect.height / 2;
    
    // Hitung rotasi (maksimal 10 derajat)
    const rotateX = ((y - centerY) / centerY) * -10;
    const rotateY = ((x - centerX) / centerX) * 10;
    
    setTilt({ x: rotateX, y: rotateY });
  };

  const handleMouseLeave = () => {
    setIsHovered(false);
    setTilt({ x: 0, y: 0 });
  };

  return (
    <div 
      className="flex-shrink-0 w-[85vw] md:w-[60vw] lg:w-[45vw] h-[70vh] md:h-[80vh] flex items-center justify-center snap-center perspective-1000"
    >
      <div 
        ref={cardRef}
        onMouseMove={handleMouseMove}
        onMouseEnter={() => setIsHovered(true)}
        onMouseLeave={handleMouseLeave}
        className="relative w-full h-full max-h-[800px] rounded-[2rem] overflow-hidden group cursor-none transition-transform duration-200 ease-out"
        style={{
          transform: isHovered 
            ? `rotateX(${tilt.x}deg) rotateY(${tilt.y}deg) scale3d(1.02, 1.02, 1.02)` 
            : 'rotateX(0deg) rotateY(0deg) scale3d(1, 1, 1)',
          boxShadow: isHovered ? '0 25px 50px -12px rgba(220, 38, 38, 0.25)' : '0 10px 30px -10px rgba(0,0,0,0.5)'
        }}
      >
        {/* Gambar Latar dengan efek Parallax Zoom */}
        <div className="absolute inset-0 overflow-hidden bg-[#0a0a0a]">
          <img 
            src={item.img} 
            alt={item.client} 
            className="w-full h-full object-cover grayscale brightness-50 group-hover:grayscale-0 group-hover:brightness-75 transition-all duration-700 transform scale-110 group-hover:scale-100 origin-center"
          />
        </div>

        {/* Gradasi Gelap agar Teks Terbaca */}
        <div className="absolute inset-0 bg-gradient-to-t from-black/90 via-black/40 to-transparent opacity-80 group-hover:opacity-100 transition-opacity duration-500"></div>

        {/* Konten Text (The Impact) */}
        <div className="absolute inset-0 p-8 md:p-12 flex flex-col justify-end">
          
          <div className="flex justify-between items-end mb-6 border-b border-white/20 pb-6">
            <div>
              <span className="text-red-500 text-[10px] md:text-xs font-black tracking-[0.3em] uppercase block mb-2">
                {item.category}
              </span>
              <h3 className="text-3xl md:text-5xl font-black text-white tracking-tighter uppercase leading-none transform translate-y-4 group-hover:translate-y-0 opacity-80 group-hover:opacity-100 transition-all duration-500">
                {item.client}
              </h3>
            </div>
            <span className="text-4xl md:text-6xl font-black text-transparent stroke-text opacity-20 group-hover:opacity-50 transition-opacity duration-500">
              {item.id}
            </span>
          </div>

          <div className="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-12 transform translate-y-8 opacity-0 group-hover:translate-y-0 group-hover:opacity-100 transition-all duration-500 delay-100">
            <div>
              <span className="text-[9px] font-bold tracking-widest text-gray-500 uppercase block mb-2">The Challenge</span>
              <p className="text-sm md:text-base text-gray-300 font-light leading-relaxed">
                {item.challenge}
              </p>
            </div>
            <div>
              <span className="text-[9px] font-bold tracking-widest text-red-500 uppercase block mb-2">The Impact</span>
              <p className="text-sm md:text-base text-white font-medium leading-relaxed">
                {item.impact}
              </p>
            </div>
          </div>

        </div>

        {/* Custom Cursor "DRAG" / "VIEW" (hanya muncul saat di-hover) */}
        {isHovered && (
          <div className="absolute top-8 right-8 w-12 h-12 bg-red-600 rounded-full flex items-center justify-center animate-pulse pointer-events-none z-50">
            <span className="text-[8px] font-black tracking-widest text-white uppercase">See</span>
          </div>
        )}
      </div>
    </div>
  );
}

export default function PortfolioGallery() {
  const scrollRef = useRef(null);

  // Efek Horizontal Scroll Pakai Roda Mouse (Tanpa plugin tambahan)
  useEffect(() => {
    const el = scrollRef.current;
    if (!el) return;

    const onWheel = (e) => {
      if (e.deltaY === 0) return;
      e.preventDefault();
      // Mengubah scroll vertikal (mouse wheel) menjadi scroll horizontal
      el.scrollTo({
        left: el.scrollLeft + e.deltaY * 2,
        behavior: 'smooth'
      });
    };

    el.addEventListener('wheel', onWheel, { passive: false });
    return () => el.removeEventListener('wheel', onWheel);
  }, []);

  return (
    <div className="bg-[#030303] min-h-screen overflow-hidden flex flex-col pt-24 pb-12">
      
      {/* Header Halaman */}
      <div className="px-6 md:px-12 lg:px-24 shrink-0 mb-8 md:mb-12">
        <div className="flex items-center gap-4 mb-4">
          <div className="w-8 h-[1px] bg-red-600"></div>
          <span className="text-[10px] md:text-xs font-black tracking-[0.4em] text-red-500 uppercase">
            Showcase
          </span>
        </div>
        <div className="flex flex-col md:flex-row md:items-end justify-between gap-6">
          <h1 className="text-5xl md:text-7xl lg:text-8xl font-black text-white tracking-tighter uppercase leading-[0.85]">
            Engineered <br/>
            <span className="text-gray-600">Monopolies.</span>
          </h1>
          <p className="text-gray-400 font-light max-w-sm text-sm md:text-base leading-relaxed">
            Gulir untuk melihat bagaimana kami mengubah masalah bisnis menjadi dominasi digital yang absolut.
          </p>
        </div>
      </div>

      {/* Area Horizontal Scroll */}
      <div 
        ref={scrollRef}
        className="flex-grow flex items-center gap-8 md:gap-16 px-6 md:px-12 lg:px-24 overflow-x-auto hide-scrollbar snap-x snap-mandatory relative z-10"
        style={{ scrollbarWidth: 'none', msOverflowStyle: 'none' }} // Sembunyikan scrollbar bawaan
      >
        {/* Slide Pertama (Instruksi) */}
        <div className="flex-shrink-0 w-[30vw] md:w-[20vw] h-[70vh] md:h-[80vh] flex flex-col justify-center snap-center">
          <div className="flex gap-4 items-center mb-8 animate-bounce-x">
             <ArrowRight className="text-red-600" size={32} strokeWidth={1} />
             <span className="text-white font-black tracking-[0.3em] uppercase text-xs">Scroll</span>
          </div>
          <div className="h-[1px] w-full bg-white/10 relative">
             <div className="absolute top-0 left-0 h-full w-1/3 bg-red-600"></div>
          </div>
        </div>

        {/* Pemetaan Studi Kasus */}
        {cases.map((item, index) => (
          <TiltCard key={item.id} item={item} index={index} />
        ))}
        
        {/* Slide Terakhir (Penutup) */}
        <div className="flex-shrink-0 w-[50vw] md:w-[30vw] h-[70vh] md:h-[80vh] flex flex-col justify-center items-center snap-center px-12 text-center">
          <h2 className="text-3xl md:text-5xl font-black text-white uppercase tracking-tighter leading-none mb-6">
            Siap Menjadi <br/> <span className="text-red-600">Yang Berikutnya?</span>
          </h2>
          <Link 
             to="/contact" 
             className="px-8 py-4 bg-white text-black font-black uppercase tracking-widest text-xs rounded-full hover:bg-red-600 hover:text-white transition-colors duration-300"
          >
            Mulai Diskusi
          </Link>
        </div>
      </div>

      {/* Indikator Navigasi (kiri bawah) */}
      <div className="absolute bottom-12 left-6 md:left-12 lg:left-24 flex gap-4 z-20 pointer-events-none">
        <div className="w-10 h-10 rounded-full border border-white/10 flex items-center justify-center bg-[#030303]/50 backdrop-blur-sm text-gray-500">
           <ArrowLeft size={16} />
        </div>
        <div className="w-10 h-10 rounded-full border border-white/10 flex items-center justify-center bg-[#030303]/50 backdrop-blur-sm text-white">
           <ArrowRight size={16} />
        </div>
      </div>

      {/* Styling Khusus Hide Scrollbar agar rapi di semua browser */}
      <style dangerouslySetInnerHTML={{__html: `
        .hide-scrollbar::-webkit-scrollbar {
          display: none;
        }
        .stroke-text {
          -webkit-text-stroke: 1px rgba(255,255,255,0.3);
          color: transparent;
        }
        .perspective-1000 {
          perspective: 1000px;
        }
        @keyframes bounce-x {
          0%, 100% { transform: translateX(0); }
          50% { transform: translateX(10px); }
        }
        .animate-bounce-x {
          animation: bounce-x 2s infinite;
        }
      `}} />

    </div>
  );
}
