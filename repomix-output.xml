              alt="Crimson Rift Studio" 
              className="relative w-full max-w-[200px] md:max-w-[280px] mx-auto drop-shadow-[0_0_40px_rgba(220,38,38,0.3)] animate-[pulse_4s_ease-in-out_infinite]" 
            />
